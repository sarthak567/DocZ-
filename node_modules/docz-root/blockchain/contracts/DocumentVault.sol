pragma solidity ^0.8.20;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/utils/cryptography/ECDSA.sol";

contract DocumentVault is AccessControl {
    using ECDSA for bytes32;

    bytes32 public constant AUTHORITY_ROLE = keccak256("AUTHORITY_ROLE");
    bytes32 public constant LAWYER_ROLE = keccak256("LAWYER_ROLE");

    struct Document {
        string ipfsHash;
        bytes32 documentHash;
        address owner;
        uint256 timestamp;
        bool exists;
        string documentType;
        string description;
        bool isRevoked;
    }

    struct AccessGrant {
        address grantedTo;
        uint256 grantedAt;
        uint256 expiresAt;
        bool active;
    }

    mapping(bytes32 => Document) public documents;
    mapping(bytes32 => AccessGrant[]) public accessList;
    mapping(address => bytes32[]) public userDocuments;
    mapping(bytes32 => mapping(address => bool)) public pendingAccess;
    mapping(bytes32 => address[]) public accessRequests;

    event DocumentStored(
        bytes32 indexed docHash,
        address indexed owner,
        string ipfsHash,
        uint256 timestamp,
        string documentType
    );

    event DocumentVerified(
        bytes32 indexed docHash,
        address indexed verifier,
        bool isValid,
        uint256 timestamp
    );

    event AccessGranted(
        bytes32 indexed docHash,
        address indexed grantedTo,
        uint256 expiresAt
    );

    event AccessRevoked(
        bytes32 indexed docHash,
        address indexed revokedFrom
    );

    event DocumentRevoked(
        bytes32 indexed docHash,
        address indexed owner
    );

    event AccessRequested(
        bytes32 indexed docHash,
        address indexed requester
    );

    constructor() {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
    }

    function storeDocument(
        string memory _ipfsHash,
        bytes32 _documentHash,
        string memory _documentType,
        string memory _description
    ) external returns (bytes32) {
        require(bytes(_ipfsHash).length > 0, "IPFS hash required");
        require(_documentHash != bytes32(0), "Invalid document hash");

        bytes32 docHash = _documentHash;

        require(!documents[docHash].exists, "Document already exists");

        documents[docHash] = Document({
            ipfsHash: _ipfsHash,
            documentHash: _documentHash,
            owner: msg.sender,
            timestamp: block.timestamp,
            exists: true,
            documentType: _documentType,
            description: _description,
            isRevoked: false
        });

        userDocuments[msg.sender].push(docHash);

        emit DocumentStored(docHash, msg.sender, _ipfsHash, block.timestamp, _documentType);

        return docHash;
    }

    function verifyDocument(bytes32 _docHash) external returns (bool) {
        require(documents[_docHash].exists, "Document not found");

        Document memory doc = documents[_docHash];
        bool isValid = !doc.isRevoked;

        if (hasRole(AUTHORITY_ROLE, msg.sender) || hasRole(LAWYER_ROLE, msg.sender)) {
            require(
                doc.owner == msg.sender ||
                hasAccess(_docHash, msg.sender) ||
                hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
                "No access to verify"
            );
        }

        emit DocumentVerified(_docHash, msg.sender, isValid, block.timestamp);

        return isValid;
    }

    function verifyDocumentWithHash(
        bytes32 _originalHash,
        bytes32 _claimedHash
    ) external returns (bool) {
        require(documents[_originalHash].exists, "Document not found");

        Document memory doc = documents[_originalHash];
        bool hashMatches = doc.documentHash == _claimedHash;
        bool isValid = hashMatches && !doc.isRevoked;

        emit DocumentVerified(_originalHash, msg.sender, isValid, block.timestamp);

        return isValid;
    }

    function requestAccess(bytes32 _docHash) external {
        require(documents[_docHash].exists, "Document not found");
        require(documents[_docHash].owner != msg.sender, "You are the owner");

        pendingAccess[_docHash][msg.sender] = true;
        accessRequests[_docHash].push(msg.sender);

        emit AccessRequested(_docHash, msg.sender);
    }

    function grantAccess(
        bytes32 _docHash,
        address _grantedTo,
        uint256 _duration
    ) external {
        require(documents[_docHash].exists, "Document not found");
        require(
            documents[_docHash].owner == msg.sender ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
            "Not authorized"
        );

        uint256 expiresAt = block.timestamp + _duration;

        accessList[_docHash].push(AccessGrant({
            grantedTo: _grantedTo,
            grantedAt: block.timestamp,
            expiresAt: expiresAt,
            active: true
        }));

        pendingAccess[_docHash][_grantedTo] = false;

        emit AccessGranted(_docHash, _grantedTo, expiresAt);
    }

    function revokeAccess(bytes32 _docHash, address _revokedFrom) external {
        require(documents[_docHash].exists, "Document not found");
        require(
            documents[_docHash].owner == msg.sender ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
            "Not authorized"
        );

        for (uint i = 0; i < accessList[_docHash].length; i++) {
            if (accessList[_docHash][i].grantedTo == _revokedFrom) {
                accessList[_docHash][i].active = false;
            }
        }

        pendingAccess[_docHash][_revokedFrom] = false;

        emit AccessRevoked(_docHash, _revokedFrom);
    }

    function revokeDocument(bytes32 _docHash) external {
        require(documents[_docHash].exists, "Document not found");
        require(
            documents[_docHash].owner == msg.sender ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender) ||
            hasRole(AUTHORITY_ROLE, msg.sender),
            "Not authorized"
        );

        documents[_docHash].isRevoked = true;

        emit DocumentRevoked(_docHash, msg.sender);
    }

    function hasAccess(bytes32 _docHash, address _user) public view returns (bool) {
        if (documents[_docHash].owner == _user) return true;
        if (hasRole(DEFAULT_ADMIN_ROLE, _user)) return true;
        if (hasRole(AUTHORITY_ROLE, _user)) return true;

        for (uint i = 0; i < accessList[_docHash].length; i++) {
            AccessGrant memory grant = accessList[_docHash][i];
            if (grant.grantedTo == _user && grant.active && block.timestamp < grant.expiresAt) {
                return true;
            }
        }
        return false;
    }

    function getDocument(bytes32 _docHash) external view returns (
        string memory ipfsHash,
        bytes32 documentHash,
        address owner,
        uint256 timestamp,
        string memory documentType,
        string memory description,
        bool isRevoked
    ) {
        require(documents[_docHash].exists, "Document not found");
        require(
            hasAccess(_docHash, msg.sender) ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
            "Access denied"
        );

        Document memory doc = documents[_docHash];
        return (
            doc.ipfsHash,
            doc.documentHash,
            doc.owner,
            doc.timestamp,
            doc.documentType,
            doc.description,
            doc.isRevoked
        );
    }

    function getUserDocuments(address _user) external view returns (bytes32[] memory) {
        return userDocuments[_user];
    }

    function getAccessList(bytes32 _docHash) external view returns (address[] memory, uint256[] memory, bool[] memory) {
        require(
            documents[_docHash].owner == msg.sender ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
            "Not authorized"
        );

        uint256 count = accessList[_docHash].length;
        address[] memory addresses = new address[](count);
        uint256[] memory expires = new uint256[](count);
        bool[] memory actives = new bool[](count);

        for (uint i = 0; i < count; i++) {
            addresses[i] = accessList[_docHash][i].grantedTo;
            expires[i] = accessList[_docHash][i].expiresAt;
            actives[i] = accessList[_docHash][i].active;
        }

        return (addresses, expires, actives);
    }

    function getPendingAccessRequests(bytes32 _docHash) external view returns (address[] memory) {
        require(
            documents[_docHash].owner == msg.sender ||
            hasRole(DEFAULT_ADMIN_ROLE, msg.sender),
            "Not authorized"
        );
        return accessRequests[_docHash];
    }

    function getDocumentCount() external view returns (uint256) {
        return userDocuments[msg.sender].length;
    }

    function addAuthority(address _authority) external onlyRole(DEFAULT_ADMIN_ROLE) {
        _grantRole(AUTHORITY_ROLE, _authority);
    }

    function addLawyer(address _lawyer) external onlyRole(DEFAULT_ADMIN_ROLE) {
        _grantRole(LAWYER_ROLE, _lawyer);
    }

    function supportsInterface(bytes4 interfaceId) public view override(AccessControl) returns (bool) {
        return super.supportsInterface(interfaceId);
    }
}
